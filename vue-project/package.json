{
  "name": "vue-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 8081",
    "dev:author": "vite --port 8082 --mode author",
    "dev:admin": "vite --port 8083 --mode admin",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.vue --fix",
    "lint:check": "eslint . --ext .js,.vue",
    "format": "prettier --write \"src/**/*.{js,vue,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,css,scss}\""
  },
  "dependencies": {
    "axios": "^1.7.2",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.2",
    "pinia": "^2.2.0",
    "vue": "^3.5.29",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.8.1",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
